int[] numbers = { 0, 5, 0, 3, 8, 0, 2 };

int insertIndex = 0;

for (int i = 0; i < numbers.Length; i++)
{
    if (numbers[i] != 0)
    {
        numbers[insertIndex] = numbers[i];
        insertIndex++;
    }
}

for (int i = insertIndex; i < numbers.Length; i++)
{
    numbers[i] = 0;
}

for (int i = 0; i < numbers.Length; i++)
{
    Console.WriteLine(numbers[i]);
}